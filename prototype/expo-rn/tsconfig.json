{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "types": ["node", "react", "react-native"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["app", "src", "convex", "test", "expo-env.d.ts"]
}
